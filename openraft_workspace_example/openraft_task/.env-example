# Node name used by this process (override per node if needed).
LIBP2P_SELF_NAME=node1
# Bootstrap node name to dial on startup (matches default "node<N>" names).
LIBP2P_BOOTSTRAP_NAME=node2
# Shared DB root for all nodes.
DB_ROOT=/tmp/libp2p_openraft_rocksdb_demo/cluster
# Axum HTTP listen addresses for each node.
NODE1_HTTP=127.0.0.1:3001
NODE2_HTTP=127.0.0.1:3002
NODE3_HTTP=127.0.0.1:3003

# Redis-compatible cache settings. Valkey uses the redis:// URL scheme.
REDIS_PORT=6380
REDIS_URL=redis://127.0.0.1:6380/
AUTO_START_REDIS=auto
DISABLE_SQLITE_CACHE=0
VALKEY_CONFIG_DIR=config/valkey
VALKEY_CONFIG_FILE=config/valkey/valkey.conf
