package demo:actor;

/// Typed records shared between the WASM guest and the Rust host.
/// Both wit_bindgen (guest) and wasmtime::component::bindgen! (host) generate
/// identical Rust structs from these definitions, eliminating JSON on the hot path.
interface host-actor {
  /// A proactive message pushed by the host into StoreState.host_to_wasm_rx.
  record host-message {
    sequence: u64,
    payload: string,
  }

  /// A message constructed by the WASM guest and sent through StoreState.host_actor_tx.
  record guest-message {
    tick: s32,
    last-handled: u64,
    last-host-reply: s32,
    payload: string,
  }

  /// The typed reply that StoreState sends back for every guest-message.
  record actor-response {
    handled: u64,
    reply: s32,
    message: string,
  }

  /// The single actor state value. The Rust host owns this value and passes it
  /// through the WASM `handle-call` callback; WASM returns the next state.
  record actor-state {
    tick: s32,
    last-host-reply: s32,
    elapsed-since-push: s32,
    last-response: actor-response,
  }

  enum actor-msg-kind {
    tick,
    host-message,
  }

  record actor-msg {
    kind: actor-msg-kind,
    host-message: option<host-message>,
  }

  /// Synchronous request-reply: WASM sends a guest-message and host returns the
  /// typed ActorResponse.
  send-to-host: func(msg: guest-message) -> actor-response;
}

world actor-world {
  import host-actor;

  export wasm-actor: interface {
    use host-actor.{actor-msg, actor-state};

    handle-call: func(msg: actor-msg, state: actor-state) -> actor-state;
    render-state: func(state: actor-state) -> string;
  }
}
