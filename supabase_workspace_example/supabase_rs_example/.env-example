SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key
SUPABASE_SCHEMA=public

# Demo table and columns used by src/main.rs examples
SUPABASE_EXAMPLE_TABLE=todos
SUPABASE_DEMO_NAME_COLUMN=name
SUPABASE_DEMO_STATUS_COLUMN=status

# Safe defaults: only read examples run.
SUPABASE_RUN_WRITE_EXAMPLES=false
SUPABASE_RUN_RPC_EXAMPLES=false

# Optional read filters
# SUPABASE_FILTER_COLUMN=status
# SUPABASE_FILTER_VALUE=active
# SUPABASE_IN_FILTER_COLUMN=status
# SUPABASE_IN_FILTER_VALUES=active,pending
# SUPABASE_TEXT_SEARCH_COLUMN=content
# SUPABASE_TEXT_SEARCH_VALUE=rust

# Optional RPC examples
# SUPABASE_RPC_FUNCTION=health_check
# SUPABASE_RPC_PARAMS_JSON={"ping":"pong"}

# Optional: Disable nightly warning messages
SUPABASE_RS_NO_NIGHTLY_MSG=true

# Optional: Use alternative endpoint format
SUPABASE_RS_DONT_REST_V1_URL=false
